mp_Ох, ну... ее со мной нет. Ты ведь не против?}"]},{"code":117,"indent":1,"parameters":[133]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["\\nr<{Трилл}>{dialogs_swamp_camp_Против? Нет, конечно, заходи!}"]},{"code":117,"indent":1,"parameters":[132]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["\\n<{Eirik}>{dialogs_swamp_camp_Ты вроде как часто ходишь вокруг дома Тины?}"]},{"code":117,"indent":1,"parameters":[133]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["\\nr<{Трилл}>{dialogs_swamp_camp_Что? Тебе это Клэр сказала?}"]},{"code":117,"indent":1,"parameters":[132]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["\\n<{Eirik}>{dialogs_swamp_camp_Ну... Ты вроде как творческая личность, да? Ценитель экзотики. Нет ничего такого в том, что тебе не дает покоя человеческая девушка.}"]},{"code":117,"indent":1,"parameters":[133]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["\\nr<{Трилл}>{dialogs_swamp_camp_Понятно. Ее сестра опять нажаловалась. Хочешь правду, а?}"]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["\\nr<{Трилл}>{dialogs_swamp_camp_Клэр ревнует меня! Она делает из этого драму, потому что сама с ума по мне сходит!}"]},{"code":117,"indent":1,"parameters":[132]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["\\n<{Eirik}>{dialogs_swamp_camp_Ого, с ума по тебе сходит! Так ты у нас сердцеед!}"]},{"code":117,"indent":1,"parameters":[133]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["\\nr<{Трилл}>{dialogs_swamp_camp_Ничего смешного! Клэр злится, что мне нравится ее сестра.}"]},{"code":117,"indent":1,"parameters":[132]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["\\n<{Eirik}>{dialogs_swamp_camp_Хочешь сказать, что сестры из-за тебя переругались?}"]},{"code":117,"indent":1,"parameters":[133]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["\\nr<{Трилл}>{dialogs_swamp_camp_Если бы это было так, было бы, конечно, довольно интригующе! Но, нет, не совсем.}"]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["\\nr<{Трилл}>{dialogs_swamp_camp_Во-первых, да, Клэр на меня запала, но вот Тина меня совершенно не замечает.}"]},{"code":117,"indent":1,"parameters":[132]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["\\n<{Eirik}>{dialogs_swamp_camp_(Бедолага.)}"]},{"code":117,"indent":1,"parameters":[133]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["\\nr<{Трилл}>{dialogs_swamp_camp_А во-вторых, Клэр и так всю жизнь недолюбливала сестру. Я, отчасти, просто повод. Последняя капля.}"]},{"code":117,"indent":1,"parameters":[44]},{"code":117,"indent":1,"parameters":[132]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["\\n<{Eirik}>{dialogs_swamp_camp_Серьезно?}"]},{"code":117,"indent":1,"parameters":[133]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["\\nr<{Трилл}>{dialogs_swamp_camp_Она не показывает это дома при отце, но черт! Клэр ненавидит Тину!}"]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["\\nr<{Трилл}>{dialogs_swamp_camp_Она у нее и сестра ненастоящая, и лягушка... Помню, она мне как-то между делом сказала, зря я заглядываюсь на Тину.}"]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["\\nr<{Трилл}>{dialogs_swamp_camp_Дескать, племя ее все равно не признает моей невестой, ведь она не одна из нас.}"]},{"code":117,"indent":1,"parameters":[45]},{"code":117,"indent":1,"parameters":[132]},{"code":101,"indent":1,"parameters":["",0,0,2,""]