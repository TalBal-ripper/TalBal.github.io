:0,"parameters":[133]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\nr<{Вождь}>{dialogs_swamp_camp_Да.}"]},{"code":117,"indent":0,"parameters":[44]},{"code":117,"indent":0,"parameters":[132]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_swamp_camp_Ого!}"]},{"code":117,"indent":0,"parameters":[133]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\nr<{Вождь}>{dialogs_swamp_camp_Грядут большие перемены, Эйрик. Туман слабеет. Скоро люди за рекой очнутся.}"]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\nr<{Вождь}>{dialogs_swamp_camp_Мысль, что в обозримом будущем они могут получить подкрепление из-за моря сделает их смелее.}"]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\nr<{Вождь}>{dialogs_swamp_camp_Не знаю, кому суждено победить в грядущей войне, но в такие времена не разбрасываются друзьями, верно?}"]},{"code":117,"indent":0,"parameters":[41]},{"code":117,"indent":0,"parameters":[132]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_swamp_camp_Ну... кхм. Может войны можно будет избежать?}"]},{"code":117,"indent":0,"parameters":[133]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\nr<{Вождь}>{dialogs_swamp_camp_Может быть. Я хотел бы этого. Может быть, это возможно. Кто знает.}"]},{"code":117,"indent":0,"parameters":[5]},{"code":356,"indent":0,"parameters":["Quest 13 Complete Objective 5"]},{"code":356,"indent":0,"parameters":["Quest 13 Show Objective 6"]},{"code":356,"indent":0,"parameters":["Quest 13 Change Description Entry To 6"]},{"code":205,"indent":0,"parameters":[3,{"list":[{"code":16,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":true}]},{"code":505,"indent":0,"parameters":[{"code":16,"indent