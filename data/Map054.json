{"id":3,"name":"Вождь Крейг","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"frog_tribe","direction":2,"pattern":1,"characterIndex":0},"list":[{"code":117,"indent":0,"parameters":[41]},{"code":117,"indent":0,"parameters":[132]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_swamp_camp_Приветствую, Вождь.}"]},{"code":117,"indent":0,"parameters":[133]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\nr<{Вождь}>{dialogs_swamp_camp_Эйрик?}"]},{"code":117,"indent":0,"parameters":[132]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_swamp_camp_Я хотел спросить о том, что произошло на площади.}"]},{"code":117,"indent":0,"parameters":[133]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\nr<{Вождь}>{dialogs_swamp_camp_Эйрик, знай, тебя рады тут видеть.}"]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\nr<{Вождь}>{dialogs_swamp_camp_Тот, кто пытался отравить тебя, каковы бы ни были его мотивы, будет жестоко наказан.}"]},{"code":117,"indent":0,"parameters":[132]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_swamp_camp_Нет, вождь, я не про это. Ну, то есть, и про это тоже, но скорее я хотел спросить... Почему вы вообще вызвали меня?}"]},{"code":117,"indent":0,"parameters":[133]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\nr<{Вождь}>{dialogs_swamp_camp_Ты спас нас. Помог племени.}"]},{"code":117,"indent":0,"parameters":[132]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_swamp_camp_Да, но... Для чего? Позвали в круг? Для чего вы хотели принять меня в племя?}"]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_swamp_camp_Для меня это большая честь ясно, но для вас, это ведь... Это ведь серьезный шаг, верно? Почему?}"]},{"code":117,"indent":0,"parameters":[133]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\nr<{Вождь}>{dialogs_swamp_camp_Есть ли у меня планы на тебя? Вот что ты спрашиваешь?}"]},{"code":117,"indent":0,"parameters":[132]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>..."]},{"code":117,"indent":0,"parameters":[133]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\nr<{Вождь}>{dialogs_swamp_camp_Люди за рекой, скажи. Они уже знают, что Туман ослаб?}"]},{"code":117,"indent":0,"parameters":[132]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_swamp_camp_Наверное.}"]},{"code":117,"indent":0,"parameters":[133]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\nr<{Вождь}>{dialogs_swamp_camp_Наверное?}"]},{"code":117,"indent":0,"parameters":[132]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_swamp_camp_Не знаю, насколько мне верят. Но да, я пытался им все объяснить. Говорил, что через туман теперь можно прорваться.}"]},{"code":117,"indent":0,"parameters":[133]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\nr<{Вождь}>{dialogs_swamp_camp_Значит, все уже произошло. Теперь бы нам лучше знать, что именно предпримут по ту сторону реки.}"]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\nr<{Вождь}>{dialogs_swamp_camp_Когда они поймут, что произошло, то начнут действовать.}"]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\nr<{Вождь}>{dialogs_swamp_camp_Нельзя позволить, чтобы то, что они сделают дальше, стало для нас неожиданностью.}"]},{"code":117,"indent":0,"parameters":[42]},{"code":117,"indent":0,"parameters":[132]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_swamp_camp_Вот как?}"]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_swamp_camp_(Меня буквально вербуют!)}"]},{"code":117,"indent":0,"parameters":[45]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_swamp_camp_(Интересно, смогу ли я что с этого получить?)}"]},{"code":117,"indent":0,"parameters":[133]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\nr<{Вождь}>{dialogs_swamp_camp_Ты хотел честного разговора. Вот он. Я и не собирался водить тебя за нос.}"]},{"code":117,"indent":0,"parameters":[132]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_swamp_camp_Но что, если я не хочу вмешиваться в местную политику?}"]},{"code":117,"indent":0,"parameters":[133]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\nr<{Вождь}>{dialogs_swamp_camp_Я пойму это. Ты должен знать, что я говорил тебе только правду.}"]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\nr<{Вождь}>{dialogs_swamp_camp_Я правда ценю твою помощь племени. Ты спас нас от большой беды.}"]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\nr<{Вождь}>{dialogs_swamp_camp_Это не капкан, и мое предложение дружбы было искренним. Тебе решать, как к нему относится.}"]},{"code":117,"indent":0,"parameters":[132]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>..."]},{"code":117,"indent":0,"parameters":[41]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_swamp_camp_А что насчет других членов племени? Не всем нравятся новые друзья.}"]},{"code":117,"indent":0,"parameters":[133]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\nr<{Вождь}>{dialogs_swamp_camp_Я не знаю, кто напал на тебя. Никто из моих воинов не пошел бы против моей воли.}"]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\nr<{Вождь}>{dialogs_swamp_camp_Хотя, быть может, я стал слишком стар и слишком слеп.}"]},{"code":117,"indent":0,"parameters":[5]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true},{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":209,"switch1Valid":true,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"frog_tribe","direction":2,"pattern":1,"characterIndex":0},"list":[{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true},{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":true,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":