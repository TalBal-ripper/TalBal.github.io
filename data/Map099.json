{"id":1,"name":"Торговец","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"People1","direction":2,"pattern":1,"characterIndex":4},"list":[{"code":102,"indent":0,"parameters":[["{Выбор_Светильники в катакомбах} <<!objComp(21,4) || questAdded(22)>>","{Выбор_По поводу монет...}<<!questAdded(22) || objComp(22,1)>>","{Торговать}","{Уйти}"],3,0,2,0]},{"code":402,"indent":0,"parameters":[0,"{Выбор_Светильники в катакомбах} <<!objComp(21,4) || questAdded(22)>>"]},{"code":117,"indent":1,"parameters":[41]},{"code":117,"indent":1,"parameters":[4]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<{Eirik}>{Эйрик (норма)_У вас есть жидкость, как ее... Люминесцентная?_dialogs_in_the_wake_of_fogwalker}"]},{"code":117,"indent":1,"parameters":[3]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\nr<{Торговец}>{Торговец_А что у тебя за испаритель?_dialogs_in_the_wake_of_fogwalker}"]},{"code":117,"indent":1,"parameters":[4]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<{Eirik}>{Эйрик (норма)_Ну... Я хочу обследовать канализации, и мне нужно включить там лампы._dialogs_in_the_wake_of_fogwalker}"]},{"code":117,"indent":1,"parameters":[3]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\nr<{Торговец}>{Торговец_Ага, знаю, там стоят такие старые щитки. Тебе нужна полторашка._dialogs_in_the_wake_of_fogwalker}"]},{"code":117,"indent":1,"parameters":[4]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<{Eirik}>{Эйрик (норма)_Чего?_dialogs_in_the_wake_of_fogwalker}"]},{"code":117,"indent":1,"parameters":[3]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\nr<{Торговец}>{Торговец_Колба на тысячу пятьсот. У меня валяется одна такая. Но тебе я её не продам._dialogs_in_the_wake_of_fogwalker}"]},{"code":117,"indent":1,"parameters":[44]},{"code":117,"indent":1,"parameters":[4]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<{Eirik}>{Эйрик (удивление)_Почему?_dialogs_in_the_wake_of_fogwalker}"]},{"code":117,"indent":1,"parameters":[3]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\nr<{Торговец}>{Торговец_Потому что вам, молодым людям, кажется, что бродить по канализации — это такое веселое развлечение. Но там опасно, особенно одному!_dialogs_in_the_wake_of_fogwalker}"]},{"code":117,"indent":1,"parameters":[41]},{"code":117,"indent":1,"parameters":[4]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<{Eirik}>{Эйрик (норма)_Во-первых, я пойду туда не один, а во-вторых, это не для развлечения._dialogs_in_the_wake_of_fogwalker}"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<{Eirik}>{Эйрик (норма)_Мы с... Моей институтской подругой проводим важное историческое расследование!_dialogs_in_the_wake_of_fogwalker}"]},{"code":117,"indent":1,"parameters":[3]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\nr<{Торговец}>{Торговец_Вот вдвоем с подругой вы там и сгинете!_dialogs_in_the_wake_of_fogwalker}"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\nr<{Торговец}>{Торговец_Катакомбы кишат тварями, уж поверь! Раньше я сам туда спускался... По своему делу._dialogs_in_the_wake_of_fogwalker}"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\nr<{Торговец}>{Торговец_Но то было несколько лет назад. Сейчас там столько гигантских пиявок расплодилось, что они скоро на улицы повылезают!_