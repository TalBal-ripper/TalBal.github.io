s":[3]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\nr<{Рокси}>{dialogs_swamp_camp_caves_Кто же?}"]},{"code":117,"indent":0,"parameters":[4]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_swamp_camp_caves_Габл, у него есть мотив и...}"]},{"code":117,"indent":0,"parameters":[3]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\nr<{Рокси}>{dialogs_swamp_camp_caves_Парень-вилка-в-глаз?}"]},{"code":117,"indent":0,"parameters":[4]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_swamp_camp_caves_Габл, да... что значит \"парень-вилка-в-глаз\"?}"]},{"code":117,"indent":0,"parameters":[3]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\nr<{Рокси}>{dialogs_swamp_camp_caves_Как-то он хвастал друзьям, что может убить мышь вилкой, а потом такой:}"]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\nr<{Рокси}>{dialogs_swamp_camp_caves_*басит* \"Кстати слышу тут одну\"... и бац!}"]},{"code":117,"indent":0,"parameters":[44]},{"code":117,"indent":0,"parameters":[4]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_swamp_camp_caves_...бац?}"]},{"code":117,"indent":0,"parameters":[3]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\nr<{Рокси}>{dialogs_swamp_camp_caves_Метнул вилку прямо в мышь. Не в меня, нет, в другую.}"]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\\nr<{Рокси}>{dialogs_swamp_camp_caves_Ну она сама дура, что подставилась, ничего удивительного, что он ее услышал. Но метает он вилки знатно, да!}"]},{"code":117,"indent":0,"parameters":[4]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":[