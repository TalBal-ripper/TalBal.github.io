{"id":3,"name":"Сценка","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":211,"indent":0,"parameters":[1]},{"code":222,"indent":0,"parameters":[]},{"code":108,"indent":0,"parameters":["СКИП СЦЕНЫ ФАГОПА"]},{"code":205,"indent":0,"parameters":[-1,{"list":[{"code":4,"indent":null},{"code":4,"indent":null},{"code":16,"indent":null},{"code":0}],"repeat":false,"skippable":true,"wait":true}]},{"code":505,"indent":0,"parameters":[{"code":4,"indent":null}]},{"code":505,"indent":0,"parameters":[{"code":4,"indent":null}]},{"code":505,"indent":0,"parameters":[{"code":16,"indent":null}]},{"code":213,"indent":0,"parameters":[-1,6,true]},{"code":117,"indent":0,"parameters":[44]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_fagop_home_Боже! Кажется оторвался!}"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_fagop_home_\"Лачуга подходит под описание Мэри... Лишь бы я не ошибся!\"}"]},{"code":117,"indent":0,"parameters":[41]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_fagop_home_Никогда бы не подумал, что лягушки могу так быстро бегать...}"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_fagop_home_Ох! И так больно бить! Кажется я сломал ребро!}"]},{"code":117,"indent":0,"parameters":[5]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\nr<{???}>{dialogs_fagop_home_Проходи, человек!}"]},{"code":117,"indent":0,"parameters":[44]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_fagop_home_Эм... Мистер Фагоп? Это вы?}"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_fagop_home_Мистер Фагоп, вы только не злитесь, ладно?}"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_fagop_home_Я не хотел \"топтать священные болота\" или вроде того... Я поговорить пришел!}"]},{"code":355,"indent":0,"parameters":["ReducePicture(1, 1);"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\nr<{dialogs_fagop_home_Фагоп}>{dialogs_fagop_home_Не бойся, человек, тебя здесь никто не тронет.}"]},{"code":117,"indent":0,"parameters":[5]},{"code":356,"indent":0,"parameters":["LAYER REMOVE 31 1"]},{"code":205,"indent":0,"parameters":[-1,{"list":[{"code":45,"parameters":["Move To: 8, 6"],"indent":null},{"code":0}],"repeat":false,"skippable":true,"wait":true}]},{"code":505,"indent":0,"parameters":[{"code":45,"parameters":["Move To: 8, 6"],"indent":null}]},{"code":205,"indent":0,"parameters":[-1,{"list":[{"code":3,"indent":null},{"code":19,"indent":null},{"code":4,"indent":null},{"code":0}],"repeat":false,"skippable":true,"wait":true}]},{"code":505,"indent":0,"parameters":[{"code":3,"indent":null}]},{"code":505,"indent":0,"parameters":[{"code":19,"indent":null}]},{"code":505,"indent":0,"parameters":[{"code":4,"indent":null}]},{"code":230,"indent":0,"parameters":[45]},{"code":213,"indent":0,"parameters":[-1,1,true]},{"code":117,"indent":0,"parameters":[43]},{"code":355,"indent":0,"parameters":["ReducePicture(1, 2);"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_fagop_home_Мэри?!. ...что ты здесь?..}"]},{"code":355,"indent":0,"parameters":["ReducePicture(1, 1);"]},{"code":117,"indent":0,"parameters":[46]},{"code":117,"indent":0,"parameters":[3]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\nr<{Merigold}>{dialogs_fagop_home_Чаю?}"]},{"code":117,"indent":0,"parameters":[42]},{"code":117,"indent":0,"parameters":[4]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_fagop_home_Ну нет... нет-нет-нет, это уже слишком!}"]},{"code":117,"indent":0,"parameters":[3]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\nr<{Merigold}>{dialogs_fagop_home_Ты все-таки попался страже. Не такой уж ты ловкий, как думаешь.}"]},{"code":117,"indent":0,"parameters":[5]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\nr<{dialogs_fagop_home_Фагоп}>{dialogs_fagop_home_И тем не менее он явился, Мэригольд.}"]},{"code":117,"indent":0,"parameters":[46]},{"code":355,"indent":0,"parameters":["ReducePicture(2, 2);"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\nr<{Merigold}>{dialogs_fagop_home_Видишь? Я же говорила. Эйрик буквально самый упрямый человек на земле. Он то, что нам нужно.}"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\nr<{Merigold}>{dialogs_fagop_home_Присаживайся, милый.}"]},{"code":117,"indent":0,"parameters":[42]},{"code":117,"indent":0,"parameters":[4]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_fagop_home_Нет-нет... Этого просто не может быть! Ты с самого начала могла придти сюда сама за своими долбанными пиявками!}"]},{"code":117,"indent":0,"parameters":[3]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\nr<{Merigold}>{dialogs_fagop_home_Пиявками? Ах, да... Ну конечно могла! Я же здесь.}"]},{"code":117,"indent":0,"parameters":[4]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_fagop_home_То есть вся это идиотская история была подстроена?! Очередной \"хитрый\" план Мэригольд!}"]},{"code":117,"indent":0,"parameters":[3]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\nr<{Merigold}>{dialogs_fagop_home_Не то, чтобы сильно хитрый. Скорее, я импровизировала!}"]},{"code":117,"indent":0,"parameters":[4]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_fagop_home_Зачем?! Чего ты хотела добиться?}"]},{"code":355,"indent":0,"parameters":["ReducePicture(1, 1);"]},{"code":117,"indent":0,"parameters":[5]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\nr<{dialogs_fagop_home_Фагоп}>{dialogs_fagop_home_Я не знаю, про что ты говоришь, человек... Мэригольд просто хотела, чтобы я увидел тебя, и только. Зачем кричать?}"]},{"code":117,"indent":0,"parameters":[44]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_fagop_home_Что? Ты хотела меня с ним познакомить? В этом все дело?}"]},{"code":117,"indent":0,"parameters":[3]},{"code":117,"indent":0,"parameters":[46]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\nr<{Merigold}>{dialogs_fagop_home_Именно!}"]},{"code":355,"indent":0,"parameters":["ReducePicture(2, 1);"]},{"code":117,"indent":0,"parameters":[5]},{"code":213,"indent":0,"parameters":[-1,1,true]},{"code":117,"indent":0,"parameters":[42]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_fagop_home_\"Слова\", Мэригольд, \"Слова\"! Ты знакома с такой концепцией!?}"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_fagop_home_\"Привет, Эйрик, удачно зашел, я как раз хотела познакомить тебя с моим старым другом - Фагопом!\"}"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<{Eirik}>{dialogs_fagop_home_\"БУДЕТЕ ЗНАКОМЫ!\"}"]},{"code":1